<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="false"
        android:largeHeap="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!-- Foreground Service de telemetria GPS -->
        <service
            android:name=".telemetry.LocationTelemetryForegroundService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- Boot receiver para reiniciar telemetria após reboot -->
        <receiver
            android:name=".telemetry.TelemetryTrackingBootReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>

    <!-- Permissions -->

    <!-- Internet e rede -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Câmera (QR Code Scanner) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Localização (GPS do motorista) -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Notificações Push (preparação para Fase 5) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Vibração (para notificações locais) -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Wake Lock (para background GPS tracking) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Boot completed (reiniciar telemetria após reboot) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Isenção de otimização de bateria -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Alarme exato para reiniciar serviço (Android 12+) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- Full-screen intent for arrival alert (Android < 14 only) -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- moveTaskToFront for arrival alert (Android 14+) -->
    <uses-permission android:name="android.permission.REORDER_TASKS" />

    <!-- Draw over other apps — allows launching activity from background (Uber-style alert) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
</manifest>
